# =====================================================
# 한국투자증권 KIS API 환경 설정
# 이 파일을 복사하여 .env 로 저장 후 실제 값으로 채워주세요.
# cp .env.example .env
# =====================================================

# --- 계정 정보 (KIS 개발자센터에서 발급) ---
KIS_APP_KEY=발급받은_APP_KEY
KIS_APP_SECRET=발급받은_APP_SECRET

# 계좌번호 형식: XXXXXXXX-XX (예: 12345678-01)
KIS_ACCOUNT_NO=12345678-01

# --- 투자 모드 ---
# true  = 모의투자 (안전하게 테스트)
# false = 실전투자 (실제 돈 거래)
KIS_IS_MOCK=true

# --- 감시 종목 (쉼표로 구분, 종목코드 6자리) ---
# 삼성전자, SK하이닉스, NAVER
WATCHLIST=005930,000660,035420,035720,051910

# --- 전략 파라미터 ---
# 래리 윌리엄스 K 계수 (0.4 ~ 0.6 권장)
K_FACTOR=0.5

# 이동평균 기간 (일)
MA_PERIOD=5

# --- 리스크 관리 ---
# 손절선 비율 (0.02 = -2%)
STOP_LOSS_RATIO=0.02

# 종목당 최대 자산 비중 (0.10 = 10%)
MAX_POSITION_RATIO=0.10

# 당일 목표 수익률 달성 시 매매 종료 (0.03 = +3%)
DAILY_PROFIT_TARGET=0.03

# --- 스케줄러 설정 ---
# 전략 체크 주기 (초)
CHECK_INTERVAL_SECONDS=60

# --- Google Gemini (AI 후보·시장 리서치) ---
# https://aistudio.google.com/apikey — 무료 티어는 일·분당 한도가 작습니다(429 시 할당량 확인).
GEMINI_API_KEY=
# 선택: 기본 gemini-2.0-flash. 429이 잦으면 AI Studio에서 결제 연동 후 동일 키로 한도 상향 가능.
# GEMINI_MODEL_AI=gemini-2.0-flash
# GEMINI_MODEL_RESEARCH=gemini-2.0-flash
# 일일 성공 호출 상한(0=무제한). 무료 티어 절약: 예) 12~20. 초과 시 Firestore 캐시·알고리즘 폴백.
# 카운터는 UTC 날짜 기준 gemini_quota/{YYYY-MM-DD}.calls
# GEMINI_DAILY_CALL_BUDGET=16

# --- 텔레그램 알림 ---
# BotFather에서 발급한 봇 토큰
TELEGRAM_BOT_TOKEN=123456:ABC-xxx...
# 메시지 받을 채팅방/채널 ID (getUpdates로 확인)
TELEGRAM_CHAT_ID=45243705
